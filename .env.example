# Clypt V3 Frontend — Environment Variables
# Copy to .env.local and fill in values

# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL for the Clypt V3 backend API server
VITE_API_BASE_URL=http://localhost:8000

# Set to false to talk to a real backend instead of the in-memory mock.
# When true (default), all API calls route through src/mocks/api.ts.
VITE_USE_MOCK_API=true

# ─── Optional ─────────────────────────────────────────────────────────────────
# Set to true to enable verbose API request logging in the browser console
VITE_DEBUG_API=false
